DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Set to False in production and list explicit origins:
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://www.example.com,https://admin.example.com

# Optional sqlite filename
SQLITE_NAME=db.sqlite3

# Brevo transactional email notifications
BREVO_API_KEY=
BREVO_SENDER_EMAIL=info@itecofs.com
BREVO_SENDER_NAME=ITEC Website
CLIENT_INBOX_EMAIL=info@itecofs.com
CLIENT_INBOX_NAME=ITEC Oilfield Services
BREVO_TIMEOUT_SECONDS=10
